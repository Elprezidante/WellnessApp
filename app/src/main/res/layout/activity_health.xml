<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥗 Healthy Recipes"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="16dp"/>

        <!-- Recipe Cards -->
        <TextView
            android:id="@+id/recipe1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥑 Avocado Salad\nIngredients: Avocado, Tomato, Onion\nInstructions: Mix and serve fresh."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"
            />

        <TextView
            android:id="@+id/recipe2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍌 Banana Smoothie\nIngredients: Banana, Milk, Honey\nInstructions: Blend until smooth."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/recipe3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍗 Grilled Chicken\nIngredients: Chicken breast, Spices\nInstructions: Grill for 20 minutes."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <!-- Extra items to FORCE scrolling -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥦 Veggie Stir Fry\nHealthy and quick."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍓 Fruit Bowl\nFresh and sweet."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥕 Carrot Juice\nBoost your vitamins."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍳 Egg Omelette\nProtein-packed breakfast."
            android:padding="16dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>
</ScrollView>