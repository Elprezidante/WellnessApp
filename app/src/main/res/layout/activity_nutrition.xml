<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#E8F5E9">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nutrition Advice"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Eat a variety of foods.\n2. Base your diet on plenty of foods rich in carbohydrates.\n3. Replace saturated with unsaturated fat.\n4. Enjoy plenty of fruits and vegetables.\n5. Reduce salt and sugar intake.\n6. Eat regularly, control the portion size.\n7. Drink plenty of fluids.\n8. Maintain a healthy body weight, feel good."
        android:textSize="16sp"
        android:lineSpacingExtra="8dp" />

</LinearLayout>